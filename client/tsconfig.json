{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "types": [
      "nativewind/types"
    ],
    "baseUrl": ".",
    "paths": {
      "@env": [
        "expo-env.d.ts"
      ],
      "@config/*": [
        "config/*"
      ],
      "@components/*": [
        "components/*"
      ]
    }
  },
  "include": [
    "expo-env.d.ts",
    "app",
    "components",
    "config",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
